.contact-page {
    max-width: 800px;
    margin: 4rem auto;
    padding: 0 5%;
}

.form-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
}

.form-group label {
    margin-bottom: 0.5rem;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.8rem;
}

.contact-form input, .contact-form textarea {
    padding: 0.8rem;
    border: 1px solid #ccc;
    background: var(--light-grey);
}

.btn-primary {
    background: var(--text);
    color: white;
    border: none;
    padding: 1rem 2rem;
    cursor: pointer;
    width: 100%;
}
